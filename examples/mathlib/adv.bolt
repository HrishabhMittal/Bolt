package mathlib

function factorial(n i32) (i32) {
    if n == 0 {
        return 1
    }
    return n * factorial(n - 1)
}

function fibonacci(n i32) (i32) {
    a := 0
    b := 1
    i := 0
    while i < n {
        temp := a + b
        a = b
        b = temp
        i = i + 1
    }
    return a
}
