package main

extern function printi32(n i32) (void);
extern function printi64(n i64) (void);
extern function printf32(n f32) (void);
extern function printf64(n f64) (void);
extern function printgstring(s string) (void);

function main()(void) {
    printi32(42);
    printi64(10000000000);

    printf32(3.14);
    printf64(2.7182818284);

    printgstring("Hello World! RAHHH");
}
